
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  ADMIN
  VENDOR
  CONSUMER
}

enum Status{
  PENDING
  APPROVED
  SUSPENDED
}

model User {
  id              String @id @default(uuid())
  email           String @unique
  password_hash   String 
  role            Role
  created_at      DateTime     @default(now())

  store           Store[]
  cart            Cart[]
  order           Order[]
}

model Store {
  id           String @id @default(uuid())
  name         String
  vendor_id    String
  status       Status @default(PENDING)
  created_at   DateTime     @default(now())
  is_deleted   Boolean      @default(false)
  
  product      Product[]
  cart         Cart[]
  order        Order[]

  vendor      User @relation(fields: [vendor_id], references:[id])
}

model Product {
  id            String @id @default(uuid())
  name          String
  descriptions  String
  stock         Int
  price         Int
  store_id      String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  is_published  Boolean @default(false)
  is_deleted    Boolean @default(false)

  productCategories   ProductCategories[]
  cartItem       CartItem[]
  OrderItem    OrderItem[]

  store         Store @relation(fields: [store_id], references:[id])
}

model Categories {
  id          String  @id @default(uuid())
  name        String

  productCategories   ProductCategories[]
}

model ProductCategories {
  id            String  @id @default(uuid())
  product_id    String  
  categories_id String

  product       Product @relation(fields: [product_id], references:[id])
  categories    Categories @relation(fields: [categories_id], references:[id])
}

model Cart {
  id          String  @id  @default(uuid())
  user_id     String
  store_id    String
  created_at  DateTime    @default(now())

  cartItem    CartItem[]

  user        User @relation(fields: [user_id],references:[id])
  store       Store   @relation(fields: [store_id],references:[id])
}

model CartItem {
  id          String  @id @default(uuid())
  cart_id     String
  product_id  String
  quantity    Int

  cart        Cart @relation(fields: [cart_id],references:[id])
  product     Product @relation(fields: [product_id],references:[id])
}

enum orderStatus{
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model  Order {
  id                String @id @default(uuid())
  user_id           String
  store_id          String
  total_price       Int
  status            orderStatus @default(PENDING)
  idempotency_key   String @unique
  created_at        DateTime @default(now())

  OrderItem         OrderItem[]
  user   User  @relation(fields: [user_id], references: [id])
  store  Store @relation(fields: [store_id], references: [id])
}

model OrderItem {
  id                String @id @default(uuid())
  order_id          String
  product_id        String
  quantity          Int
  purchase_price    Int

  order             Order @relation(fields: [order_id], references: [id])
  product           Product @relation(fields: [product_id],references:[id])            
}